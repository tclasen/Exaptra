{
  "model": {
    "provider": "local",
    "name": "example-model",
    "api_key": {
      "env": "EXAPTRA_MODEL_API_KEY"
    }
  },
  "mcp_providers": [
    {
      "name": "localrun",
      "command": "builtin",
      "execution": {
        "kind": "local"
      },
      "env": {
        "EXAPTRA_TOKEN": "example-provider-token"
      }
    }
  ],
  "tool_policy": {
    "mode": "allow_all"
  },
  "permissions": {
    "mode": "deny_by_default"
  },
  "telemetry": {
    "enabled": true,
    "sampling_rate": 1,
    "high_risk_sampling_rate": 0,
    "retention_days": 14,
    "allowed_readers": [
      "maintainers"
    ],
    "export_requires_approval": true,
    "redact_attributes": [
      "prompt",
      "message",
      "secret",
      "token"
    ]
  },
  "debug": {
    "trace": true,
    "audit": true
  }
}
