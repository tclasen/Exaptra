{
  "model": {
    "provider": "local",
    "name": "example-model",
    "api_key": {
      "env": "EXAPTRA_MODEL_API_KEY"
    }
  },
  "mcp_providers": [
    {
      "name": "localrun",
      "command": "builtin",
      "env": {
        "EXAPTRA_TOKEN": "example-provider-token"
      }
    }
  ],
  "tool_policy": {
    "mode": "allow_all"
  },
  "permissions": {
    "mode": "deny_by_default"
  },
  "debug": {
    "trace": true,
    "audit": true
  }
}
